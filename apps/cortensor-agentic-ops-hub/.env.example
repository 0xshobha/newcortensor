# ═══════════════════════════════════════════════════════
# Cortensor Agentic Ops Hub (CAOH) – Environment Variables
# ═══════════════════════════════════════════════════════
# Copy this to .env.local: cp .env.example .env.local

# ─── Cortensor Router ──────────────────────────────────
# Local: http://localhost:5010 (run your own router node)
# Docker: docker run -p 5010:5010 -e AUTH_TOKEN=default-dev-token cortensor/router:latest
# Session: Create at https://dashboard-alpha.cortensor.network/session
CORTENSOR_ROUTER_URL=http://localhost:5010
SESSION_ID=1
CORTENSOR_AUTH_TOKEN=default-dev-token

# ─── Public (client-side) ─────────────────────────────
NEXT_PUBLIC_SESSION_ID=1
NEXT_PUBLIC_ROUTER_URL=localhost:5010
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── GitHub Monitoring (optional) ─────────────────────
# Create PAT at: https://github.com/settings/tokens
# Scopes needed: public_repo, read:org
GITHUB_TOKEN=your_github_pat_here
GITHUB_ORG=cortensor

# ─── Mock Mode ────────────────────────────────────────
# Set true for development without a real Cortensor router
# Agents will return realistic mock data for demo purposes
MOCK_CORTENSOR=false
